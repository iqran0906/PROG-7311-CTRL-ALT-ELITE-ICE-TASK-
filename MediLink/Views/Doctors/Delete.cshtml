@model MediLink.Models.Doctor

@{
    ViewData["Title"] = "Delete Doctor";
}

<h2 class="mb-4">Delete Doctor</h2>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="alert alert-warning">
    Are you sure you want to delete this doctor?
</div>

<div class="card">
    <div class="card-body">
        <p><strong>First Name:</strong> @Model.FirstName</p>
        <p><strong>Last Name:</strong> @Model.LastName</p>
        <p><strong>Specialization:</strong> @Model.Specialization</p>
        <p><strong>Email:</strong> @Model.Email</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete Doctor</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>