@model MediLink.Models.Appointment

@{
    ViewData["Title"] = "Delete Appointment";
}

<h2 class="mb-4">Delete Appointment</h2>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="alert alert-warning">
    Are you sure you want to delete this appointment?
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Appointment Date:</strong> @Model.AppointmentDate.ToString("f")</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Patient:</strong> @Model.Patient?.FirstName @Model.Patient?.LastName</p>
        <p><strong>Doctor:</strong> @Model.Doctor?.FirstName @Model.Doctor?.LastName</p>
        <p><strong>Specialization:</strong> @Model.Doctor?.Specialization</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete Appointment</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>