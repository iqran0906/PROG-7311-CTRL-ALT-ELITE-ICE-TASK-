@model List<MediLink.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-primary mb-1">Appointments</h2>
        <p class="text-muted mb-0">Manage appointment schedules and statuses.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Add Appointment</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No appointments found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model)
                        {
                            <tr>
                                <td>@appointment.AppointmentDate.ToString("f")</td>
                                <td>
                                    <span class="badge bg-primary">@appointment.Status</span>
                                </td>
                                <td>@appointment.Patient?.FirstName @appointment.Patient?.LastName</td>
                                <td>@appointment.Doctor?.FirstName @appointment.Doctor?.LastName</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-sm btn-outline-info">Details</a>
                                    <a asp-action="Edit" asp-route-id="@appointment.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@appointment.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}