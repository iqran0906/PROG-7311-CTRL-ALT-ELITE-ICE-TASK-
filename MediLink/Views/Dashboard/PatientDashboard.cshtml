@model MediLink.ViewModels.PatientDashboardViewModel

@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-primary mb-1">Patient Dashboard</h2>
        <p class="text-muted mb-0">Manage your profile, appointments, and view available doctors.</p>
    </div>

    <a asp-controller="Appointments" asp-action="Create" class="btn btn-primary">Book Appointment</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center dashboard-stat-card">
            <h6 class="text-muted">My Appointments</h6>
            <h3 class="fw-bold text-primary">@Model.Appointments.Count</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center dashboard-stat-card">
            <h6 class="text-muted">Available Doctors</h6>
            <h3 class="fw-bold text-success">@Model.AvailableDoctors.Count</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center dashboard-stat-card">
            <h6 class="text-muted">Account Type</h6>
            <h3 class="fw-bold text-dark">Patient</h3>
        </div>
    </div>
</div>

@if (Model.Patient != null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h4 class="mb-0">My Profile</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Name:</strong> @Model.Patient.FirstName @Model.Patient.LastName</p>
                    <p><strong>Email:</strong> @Model.Patient.Email</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Phone Number:</strong> @Model.Patient.PhoneNumber</p>
                    <p><strong>Date of Birth:</strong> @Model.Patient.DateOfBirth.ToShortDateString()</p>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h4 class="mb-0">Available Doctors</h4>
    </div>
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-3 text-center mb-3 mb-md-0">
                <div class="doctor-avatar large-avatar mx-auto">
                    <span>@Model.Patient.FirstName.Substring(0, 1)@Model.Patient.LastName.Substring(0, 1)</span>
                </div>
            </div>
            <div class="col-md-9">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Name:</strong> @Model.Patient.FirstName @Model.Patient.LastName</p>
                        <p><strong>Email:</strong> @Model.Patient.Email</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Phone Number:</strong> @Model.Patient.PhoneNumber</p>
                        <p><strong>Date of Birth:</strong> @Model.Patient.DateOfBirth.ToShortDateString()</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
        
       
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h4 class="mb-0">My Appointments</h4>
    </div>
    <div class="card-body">
        @if (Model.Appointments.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Doctor</th>
                            <th>Specialization</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model.Appointments)
                        {
                            <tr>
                                <td>@appointment.AppointmentDate.ToString("f")</td>
                                <td>
                                    <span class="badge bg-primary">@appointment.Status</span>
                                </td>
                                <td>@appointment.Doctor?.FirstName @appointment.Doctor?.LastName</td>
                                <td>@appointment.Doctor?.Specialization</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">You do not have any appointments yet.</p>
        }
    </div>
</div>